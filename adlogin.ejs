<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>ADMIN LOGIN - ULTRA CYBERPUNK</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@900&display=swap');

  /* Reset */
  * {
    margin: 0; padding: 0; box-sizing: border-box;
  }
  html, body {
    height: 100%;
    background: linear-gradient(135deg, #0c0032, #1b0055);
    overflow: hidden;
    font-family: 'Orbitron', sans-serif;
    user-select: none;
    color: #fff;
  }

  /* Background neon fog and particles */
  body::before, body::after {
    content: '';
    position: fixed;
    pointer-events: none;
    width: 100%; height: 100%;
    top: 0; left: 0;
    z-index: 0;
    mix-blend-mode: screen;
  }
  body::before {
    background:
      radial-gradient(circle at 20% 30%, rgba(133,69,255,0.25), transparent 70%),
      radial-gradient(circle at 80% 80%, rgba(183,96,255,0.35), transparent 70%);
    filter: blur(120px);
    animation: fogMove 35s ease-in-out infinite alternate;
  }
  body::after {
    background: radial-gradient(circle at center, rgba(255,255,255,0.06) 2px, transparent 5px);
    background-size: 40px 40px;
    animation: starsDrift 70s linear infinite;
  }
  @keyframes fogMove {
    0% { transform: translate(0, 0) scale(1); }
    100% { transform: translate(-50px, 30px) scale(1.1); }
  }
  @keyframes starsDrift {
    0% { background-position: 0 0; }
    100% { background-position: 400px 400px; }
  }

  /* Container with neon pulse glow */
  .neon-card {
    position: relative;
    max-width: 480px;
    margin: auto;
    top: 10vh;
    background: rgba(10, 0, 48, 0.8);
    border-radius: 3rem;
    padding: 4rem 3.5rem 5rem 3.5rem;
    box-shadow:
      0 0 30px #a75dff88,
      0 0 80px #aa78ffcc inset,
      0 0 60px #8b3ee733;
    backdrop-filter: blur(18px);
    border: 2px solid #7b3edeaa;
    overflow: hidden;
    z-index: 10;
    animation: pulseGlow 4s ease-in-out infinite alternate;
    cursor: grab;
    transform-style: preserve-3d;
    user-select: text;
  }
  @keyframes pulseGlow {
    0% { box-shadow:
      0 0 30px #a75dff88,
      0 0 80px #aa78ffcc inset,
      0 0 60px #8b3ee733;
    }
    100% { box-shadow:
      0 0 40px #c68bffdd,
      0 0 120px #d2aaffee inset,
      0 0 90px #9a57ffbb;
    }
  }

  /* Glitch heading */
  .neon-heading {
    font-size: 4.5rem;
    font-weight: 900;
    letter-spacing: 0.15em;
    color: #ce8aff;
    position: relative;
    margin-bottom: 2.8rem;
    user-select: none;
    text-transform: uppercase;
    text-shadow:
      0 0 6px #ce8aff,
      0 0 12px #a560ff,
      0 0 18px #b873ff,
      0 0 24px #9e59ff,
      0 0 35px #ad7aff;
    animation: flickerGlitch 4s linear infinite;
  }
  .neon-heading::before, .neon-heading::after {
    content: attr(data-text);
    position: absolute;
    left: 0; top: 0;
    width: 100%;
    overflow: hidden;
    clip-path: polygon(0 45%, 100% 40%, 100% 60%, 0 65%);
  }
  .neon-heading::before {
    left: 2px;
    text-shadow: -2px 0 #ff3c87;
    animation: glitchTop 2s infinite linear alternate-reverse;
  }
  .neon-heading::after {
    left: -2px;
    text-shadow: -2px 0 #5cffdb;
    animation: glitchBot 1.5s infinite linear alternate;
  }
  @keyframes flickerGlitch {
    0%, 100% { opacity: 1; }
    20%, 25%, 55%, 60% { opacity: 0.75; }
    40%, 45%, 80% { opacity: 0.9; }
  }
  @keyframes glitchTop {
    0%, 100% { clip-path: polygon(0 45%, 100% 40%, 100% 60%, 0 65%); transform: translate(0,0); }
    50% { clip-path: polygon(0 40%, 100% 35%, 100% 55%, 0 60%); transform: translate(-3px, -2px); }
  }
  @keyframes glitchBot {
    0%, 100% { clip-path: polygon(0 80%, 100% 75%, 100% 90%, 0 95%); transform: translate(0,0); }
    50% { clip-path: polygon(0 85%, 100% 80%, 100% 95%, 0 100%); transform: translate(3px, 2px); }
  }

  /* Form inputs */
  form {
    display: flex;
    flex-direction: column;
    gap: 1.9rem;
    position: relative;
    z-index: 20;
  }
  input {
    font-family: 'Orbitron', monospace;
    font-weight: 700;
    font-size: 1.25rem;
    padding: 1.3rem 1.6rem;
    border-radius: 1.3rem;
    border: 2px solid #6300ff;
    background: linear-gradient(145deg, #1a005a, #2a007a);
    color: #ddd;
    outline-offset: 3px;
    box-shadow:
      0 0 8px #7a56ff,
      inset 0 0 12px #9a7cff;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, background-position 0.8s ease;
    background-size: 200% 200%;
    background-position: 0% 50%;
    letter-spacing: 0.07em;
  }
  input::placeholder {
    color: #b09cffaa;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 600;
    user-select: none;
  }
  input:focus {
    border-color: #d39eff;
    background-position: 100% 50%;
    box-shadow:
      0 0 18px #ca98ff,
      inset 0 0 24px #ccbbff;
    outline: none;
  }
  input:focus::placeholder {
    color: #eee;
  }

  /* Button */
  button {
    margin-top: 1.2rem;
    padding: 1.6rem 0;
    font-family: 'Orbitron', sans-serif;
    font-weight: 900;
    font-size: 1.45rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    background: linear-gradient(270deg, #b86eff, #6a35ff, #b86eff);
    background-size: 300% 300%;
    border: none;
    border-radius: 2.5rem;
    box-shadow:
      0 0 12px #b86eff,
      0 0 45px #843aff,
      0 0 70px #b46aff;
    cursor: pointer;
    position: relative;
    overflow: hidden;
    transition: background-position 3s ease, transform 0.15s ease, box-shadow 0.3s ease;
    user-select: none;
    z-index: 10;
  }
  button:hover {
    background-position: 100% 50%;
    box-shadow:
      0 0 30px #d79eff,
      0 0 60px #a564ff,
      0 0 90px #e4a8ff;
    transform: scale(1.1);
    animation: glitchButton 1.5s infinite linear alternate;
  }
  button:active {
    transform: scale(0.85);
  }
  @keyframes glitchButton {
    0%, 100% { filter: none; }
    33% { filter: drop-shadow(2px 0 #f0f) drop-shadow(-2px 0 #0ff); }
    66% { filter: drop-shadow(-2px 0 #f0f) drop-shadow(2px 0 #0ff); }
  }
  button::before {
    content: '';
    position: absolute;
    top: 0; left: -50%;
    width: 200%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.25), transparent);
    transform: skewX(-20deg);
    transition: all 0.7s ease;
  }
  button:hover::before {
    left: 100%;
    transition: all 0.7s ease;
  }

  /* Register link */
  .register-link {
    display: block;
    margin-top: 3rem;
    text-align: center;
    font-weight: 700;
    color: #d3baffcc;
    font-size: 1.1rem;
    letter-spacing: 0.1em;
    text-decoration: none;
    user-select: none;
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }
  .register-link:hover {
    color: #f6e3ff;
    text-shadow: 0 0 12px #d381ff, 0 0 20px #ac63ff;
    text-decoration: underline;
  }

  /* Scanline overlay */
  .scanline-overlay {
    pointer-events: none;
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        180deg,
        rgba(255,255,255,0.04),
        rgba(255,255,255,0.04) 1px,
        transparent 2px,
        transparent 4px
      );
    z-index: 9;
    animation: scanlineMove 6s linear infinite;
    border-radius: 3rem;
    mix-blend-mode: screen;
  }
  @keyframes scanlineMove {
    0% { background-position: 0 0; }
    100% { background-position: 0 100%; }
  }
</style>
</head>
<body>

<div class="neon-card" role="main" aria-label="Ultra Neon Admin Login Form">
  <div class="scanline-overlay"></div>

  <h1 class="neon-heading" data-text="ADMIN LOGIN">ADMIN LOGIN</h1>

  <form action="/adlogin" method="POST" autocomplete="off" novalidate>
    <input type="email" name="email" placeholder="Email" required autocomplete="email" aria-label="Email" />
    <input type="password" name="password" placeholder="Password" required autocomplete="current-password" aria-label="Password" />
    <button type="submit" aria-label="Login Admin Account">LOGIN</button>
  </form>

  <a href="/adregister" class="register-link" aria-label="Go to Admin Register">Don't have an account? Register here</a>
</div>

<script>
  // 3D card tilt
  const card = document.querySelector('.neon-card');
  card.style.transition = 'transform 0.3s ease';

  card.addEventListener('mousemove', e => {
    const rect = card.getBoundingClientRect();
    const x = e.clientX - rect.left - rect.width / 2;
    const y = e.clientY - rect.top - rect.height / 2;

    const rotateX = (-y / rect.height) * 20;
    const rotateY = (x / rect.width) * 20;

    card.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale(1.05)`;
  });
  card.addEventListener('mouseleave', () => {
    card.style.transform = 'rotateX(0) rotateY(0) scale(1)';
  });

  // Optional: button click sound
  const btn = card.querySelector('button');
  btn.addEventListener('click', e => {
    const audio = new Audio('https://actions.google.com/sounds/v1/ui/click.ogg');
    audio.volume = 0.15;
    audio.play();
  });
</script>
</body>
</html>
